# =============================================================================
# Lighthouse OS — Environment Configuration
# Copy this to .env and fill in your values
# =============================================================================

# === Databricks ===
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
# For Personal Access Token:
DATABRICKS_TOKEN=dapi_xxxxxxxxxxxxxxxxxxxx
# For Service Principal (OAuth M2M):
DATABRICKS_CLIENT_ID=9e10b129-3fdd-4b19-9276-078b466da4c0
DATABRICKS_CLIENT_SECRET=your_client_secret
DATABRICKS_HTTP_PATH=/sql/protocolv1/o/XXXX/XXXX-XXXX-XXXX
DATABRICKS_CATALOG=hive_metastore
DATABRICKS_SCHEMA=default

# === Anthropic (Claude) ===
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
CLAUDE_MODEL=claude-sonnet-4-20250514

# === Kumo.AI (Optional — enable when ready) ===
# KUMO_API_KEY=kumo_xxxxxxxxxxxxxxxxxxxx
# KUMO_API_URL=https://api.kumo.ai/v1

# === Data Sources ===
HDX_BASE_URL=https://data.humdata.org
ACLED_API_KEY=your_acled_key_here
ACLED_EMAIL=your_email@example.com

# === Application ===
LOG_LEVEL=INFO
DATA_DIR=./data
